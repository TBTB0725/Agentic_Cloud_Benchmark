  "log_parser": "def parser(log: str) -> dict[str, str]:\n    import re\n    results = {}\n    for line in log.splitlines():\n        m = re.match(r'(PASS|FAIL|SKIP):\\s+(\\S+)', line)\n        if m:\n            status, name = m.groups()\n            status = status.upper()\n            if status == \"PASS\":\n                results[name] = \"pass\"\n            elif status == \"FAIL\":\n                results[name] = \"fail\"\n            elif status == \"SKIP\":\n                results[name] = \"skip\"\n    return results",
