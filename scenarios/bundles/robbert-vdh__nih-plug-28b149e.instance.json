  "log_parser": "def parser(log: str) -> dict[str, str]:\n    import re\n    result: dict[str, str] = {}\n    for line in log.splitlines():\n        # Typical lines:\n        # test oversampling::tests::convolve_rb::test_no_wrap ... ok\n        # test oversampling::tests::convolve_rb::test_with_wrap ... ok\n        # test src/buffer.rs - buffer::Buffer<'a>::iter_blocks (line 90) ... ignored\n        m = re.match(r\"test\\s+([^\\s]+)\\s+\\.\\.\\.\\s*(ok|FAILED|ignored)\", line)\n        if m:\n            test, status = m.groups()\n            status = status.lower()\n            if status == \"ok\":\n                result[test] = \"pass\"\n            elif status == \"failed\":\n                result[test] = \"fail\"\n            elif status == \"ignored\":\n                result[test] = \"skip\"\n    return result\n",
